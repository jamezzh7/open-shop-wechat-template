<view class="page-container">
  <view class="member-header" bindtap="onHeaderTap">
    <view class="avatar-ring">
      <image
        wx:if="{{isLoggedIn && avatarUrl}}"
        class="avatar-image"
        src="{{avatarUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="avatar-circle">
        <text class="avatar-initial">{{avatarInitial}}</text>
      </view>
    </view>
    <view class="user-info">
      <text class="user-greeting">{{isLoggedIn ? nickname : welcomeText}}</text>
      <text class="user-sub">{{isLoggedIn ? '会员账户已启用' : '登录后开启会员储值与订单权益'}}</text>
    </view>
    <view class="member-pill">
      <text class="member-pill-text">{{isLoggedIn ? '会员' : '登录'}}</text>
    </view>
  </view>

  <view class="wallet-panel">
    <view class="wallet-top">
      <view>
        <text class="wallet-eyebrow">会员余额</text>
        <view class="balance-row">
          <text class="balance-symbol">¥</text>
          <text class="balance-amount">{{memberBalanceFormatted}}</text>
        </view>
      </view>
      <button class="recharge-main-btn" bindtap="onOpenRecharge">会员储值</button>
    </view>

    <view class="wallet-divider"></view>

    <view class="wallet-stats">
      <view class="wallet-stat">
        <text class="wallet-stat-value">¥{{totalStoredFormatted}}</text>
        <text class="wallet-stat-label">累计储值</text>
      </view>
      <view class="wallet-stat">
        <text class="wallet-stat-value">{{lastRechargeText}}</text>
        <text class="wallet-stat-label">最近入账</text>
      </view>
    </view>
  </view>

  <view class="section-card recharge-card">
    <view class="section-row">
      <view>
        <text class="section-title">储值档位</text>
        <text class="section-subtitle">选择常用金额，余额会保存到云端会员账户</text>
      </view>
    </view>
    <view class="plan-grid">
      <view
        wx:for="{{rechargePlans}}"
        wx:for-item="plan"
        wx:for-index="index"
        wx:key="amount"
        class="plan-item {{selectedPlanIndex === index ? 'plan-item--selected' : ''}}"
        data-index="{{index}}"
        bindtap="onSelectRechargePlan"
      >
        <text class="plan-label">{{plan.label}}</text>
        <text class="plan-amount">¥{{plan.amount}}</text>
        <text class="plan-bonus">{{plan.bonusText}}</text>
      </view>
    </view>
    <button class="recharge-confirm-btn" bindtap="onOpenRecharge">微信支付储值</button>
  </view>

  <view class="section-card">
    <view class="section-row">
      <text class="section-title">我的订单</text>
      <view class="section-link" data-tab="0" bindtap="onOrderGridTap">
        <text class="section-link-text">全部订单</text>
        <text class="section-link-arrow">›</text>
      </view>
    </view>
    <view class="order-grid">
      <view class="grid-item" data-tab="1" bindtap="onOrderGridTap">
        <view class="grid-icon-wrap grid-icon-wrap--pending">
          <text class="grid-icon-text grid-icon-text--pending">¥</text>
        </view>
        <text class="grid-label">待付款</text>
      </view>

      <view class="grid-item" data-tab="2" bindtap="onOrderGridTap">
        <view class="grid-icon-wrap grid-icon-wrap--active">
          <text class="grid-icon-text grid-icon-text--active">→</text>
        </view>
        <text class="grid-label">待收货/自提</text>
      </view>

      <view class="grid-item" data-tab="3" bindtap="onOrderGridTap">
        <view class="grid-icon-wrap grid-icon-wrap--refund">
          <text class="grid-icon-text grid-icon-text--refund">↩</text>
        </view>
        <text class="grid-label">退款/售后</text>
      </view>

      <view class="grid-item" data-tab="0" bindtap="onOrderGridTap">
        <view class="grid-icon-wrap grid-icon-wrap--all">
          <text class="grid-icon-text grid-icon-text--all">≡</text>
        </view>
        <text class="grid-label">全部订单</text>
      </view>
    </view>
  </view>

  <view class="section-card admin-card" wx:if="{{isAdmin}}" bindtap="onGoAdminOrders">
    <view class="admin-row">
      <view class="admin-icon-wrap">
        <text class="admin-icon-text">管</text>
      </view>
      <view class="admin-label-group">
        <text class="admin-label">商家管理</text>
        <text class="admin-sublabel">查看并处理待发货订单</text>
      </view>
      <text class="admin-arrow">›</text>
    </view>
    <view class="admin-notify-row">
      <view class="admin-notify-copy">
        <text class="admin-notify-title">新订单微信提醒</text>
        <text class="admin-notify-subtitle">{{orderNotifyConfigured ? (orderNotifyEnabled ? '已授权，支付成功后会推送服务通知' : '授权后无需一直盯着后台') : '待配置订阅消息模板 ID'}}</text>
      </view>
      <view
        class="admin-notify-btn {{orderNotifyEnabled ? 'admin-notify-btn--active' : ''}}"
        catchtap="onSubscribeOrderNotify"
      >
        <text class="admin-notify-btn-text">{{orderNotifyLoading ? '处理中' : (orderNotifyEnabled ? '重新授权' : '开启提醒')}}</text>
      </view>
    </view>
  </view>
</view>

<button
  class="customer-service-fab"
  open-type="contact"
  session-from="{{customerServiceSession}}"
  send-message-title="{{customerServiceTitle}}"
  send-message-path="/pages/index/index"
  show-message-card="true"
  hover-class="customer-service-fab--pressed"
>
  <image class="customer-service-fab__icon" src="/images/icons/customer-service.svg" mode="aspectFit" />
  <text class="customer-service-fab__label">联系客服</text>
</button>

<view
  class="modal-mask {{showRechargeSheet ? 'modal-mask--visible' : ''}}"
  catchtouchmove="preventScroll"
  bindtap="onCloseRechargeSheet"
>
  <view
    class="recharge-sheet {{showRechargeSheet ? 'recharge-sheet--open' : ''}}"
    catchtap="preventClose"
  >
    <view class="sheet-handle"></view>
    <text class="sheet-title">确认会员储值</text>
    <view class="recharge-summary">
      <text class="summary-label">{{selectedPlan.label}}</text>
      <view class="summary-amount-row">
        <text class="summary-symbol">¥</text>
        <text class="summary-amount">{{selectedPlan.amount}}</text>
      </view>
      <text class="summary-bonus">{{selectedPlan.bonusText}}</text>
    </view>
    <view class="sheet-actions">
      <button class="confirm-btn" loading="{{recharging}}" bindtap="onConfirmRecharge">微信支付储值</button>
      <text class="skip-link" bindtap="onCloseRechargeSheet">稍后再说</text>
    </view>
  </view>
</view>

<view
  class="modal-mask {{showLoginSheet ? 'modal-mask--visible' : ''}}"
  catchtouchmove="preventScroll"
  bindtap="onCloseLoginSheet"
>
  <view
    class="login-sheet {{showLoginSheet ? 'login-sheet--open' : ''}}"
    catchtap="preventClose"
  >
    <view class="sheet-handle"></view>
    <text class="sheet-title">完善个人信息</text>

    <view class="avatar-chooser">
      <button
        class="avatar-btn"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
      >
        <image
          wx:if="{{draftAvatarUrl}}"
          class="avatar-preview"
          src="{{draftAvatarUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-plus">+</text>
        </view>
      </button>
      <text class="avatar-hint">点击选择头像</text>
    </view>

    <view class="nickname-wrap">
      <text class="nickname-label">昵称</text>
      <input
        class="nickname-input"
        type="nickname"
        placeholder="点击填写或使用微信昵称"
        placeholder-class="nickname-placeholder"
        maxlength="20"
        value="{{draftNickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
    </view>

    <view class="sheet-actions">
      <button class="confirm-btn" bindtap="onConfirmLogin">完成</button>
      <text class="skip-link" bindtap="onCloseLoginSheet">跳过</text>
    </view>
  </view>
</view>
