.page-container {
  min-height: 100vh;
  padding: var(--space-5) var(--space-4) var(--space-10);
  background-color: var(--color-bg-subtle);
}

/* ─── Member header ───────────────────────────────────────────── */
.member-header {
  display: flex;
  align-items: center;
  padding: var(--space-5) var(--space-4);
  background-color: var(--color-surface);
  border: 2rpx solid var(--color-divider);
  border-radius: var(--radius-xl);
}

.avatar-ring {
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-pill);
  border: 2rpx solid var(--color-primary-tint);
  padding: 6rpx;
  flex-shrink: 0;
  margin-right: var(--space-4);
  overflow: hidden;
  background-color: #FFFFFF;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-pill);
  display: block;
}

.avatar-circle {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-pill);
  background-color: var(--color-primary-tint);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-initial {
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: var(--tracking-tight);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.user-greeting {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: var(--leading-tight);
  margin-bottom: var(--space-1);
}

.user-sub {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  line-height: var(--leading-normal);
}

.member-pill {
  height: 52rpx;
  padding: 0 var(--space-3);
  border-radius: var(--radius-pill);
  background-color: var(--color-primary-tint);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: var(--space-3);
}

.member-pill-text {
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-primary);
}

/* ─── Wallet ─────────────────────────────────────────────────── */
.wallet-panel {
  margin-top: var(--space-4);
  padding: var(--space-5);
  background-color: #FFFFFF;
  border-radius: var(--radius-xl);
  border: 2rpx solid var(--color-primary-tint);
  box-shadow: var(--shadow-sm);
}

.wallet-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.wallet-eyebrow {
  display: block;
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  letter-spacing: var(--tracking-wider);
  margin-bottom: var(--space-2);
}

.balance-row {
  display: flex;
  align-items: baseline;
}

.balance-symbol {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-right: var(--space-1);
}

.balance-amount {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: var(--tracking-tight);
  line-height: 1;
}

.recharge-main-btn {
  min-width: 176rpx;
  height: 72rpx;
  padding: 0 var(--space-4);
  margin: 30rpx 0 0;
  border: none;
  border-radius: var(--radius-pill);
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-size: var(--text-sm);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(143, 107, 233, 0.24);
}

.recharge-main-btn::after,
.recharge-confirm-btn::after,
.confirm-btn::after,
.avatar-btn::after {
  border: none;
}

.wallet-divider {
  height: 2rpx;
  background-color: var(--color-divider);
  margin: var(--space-5) 0 var(--space-4);
}

.wallet-stats {
  display: flex;
}

.wallet-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.wallet-stat:not(:first-child) {
  border-left: 2rpx solid var(--color-divider);
  padding-left: var(--space-4);
}

.wallet-stat-value {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.wallet-stat-label {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
}

/* ─── Section card ────────────────────────────────────────────── */
.section-card {
  background-color: var(--color-surface);
  margin-top: var(--space-4);
  border-radius: var(--radius-xl);
  padding: var(--space-5) var(--space-4);
  border: 2rpx solid var(--color-divider);
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-4);
}

.section-title {
  display: block;
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-subtitle {
  display: block;
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.section-link {
  display: flex;
  align-items: center;
}

.section-link-text {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
}

.section-link-arrow {
  font-size: var(--text-md);
  color: var(--color-text-muted);
  margin-left: 4rpx;
}

/* ─── Recharge plans ──────────────────────────────────────────── */
.recharge-card {
  padding-bottom: var(--space-4);
}

.plan-grid {
  display: flex;
  gap: var(--space-2);
}

.plan-item {
  flex: 1;
  min-width: 0;
  padding: var(--space-3) var(--space-2);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--color-border);
  background-color: var(--color-bg-subtle);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.plan-item--selected {
  border-color: var(--color-primary);
  background-color: #FFFFFF;
}

.plan-label {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-bottom: var(--space-1);
}

.plan-amount {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.plan-bonus {
  font-size: var(--text-xs);
  color: var(--color-primary);
  margin-top: var(--space-1);
  text-align: center;
  line-height: var(--leading-tight);
}

.recharge-confirm-btn {
  width: 100%;
  height: 88rpx;
  margin-top: var(--space-4);
  padding: 0;
  border: 2rpx solid rgba(143, 107, 233, 0.24);
  border-radius: var(--radius-pill);
  background-color: #FFFFFF;
  color: var(--color-text-primary);
  font-size: var(--text-base);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ─── Order status grid ───────────────────────────────────────── */
.order-grid {
  display: flex;
}

.grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2) var(--space-1);
}

.grid-item:not(:first-child) {
  border-left: 2rpx solid var(--color-divider);
}

.grid-icon-wrap {
  width: 76rpx;
  height: 76rpx;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-2);
}

.grid-icon-wrap--pending { background-color: #FEF3C7; }
.grid-icon-wrap--active  { background-color: var(--color-primary-tint); }
.grid-icon-wrap--refund  { background-color: #F3F4F6; }
.grid-icon-wrap--all     { background-color: var(--color-primary-tint); }

.grid-icon-text {
  font-size: var(--text-lg);
  font-weight: 700;
  line-height: 1;
}

.grid-icon-text--pending { color: #B45309; }
.grid-icon-text--active  { color: var(--color-primary); }
.grid-icon-text--refund  { color: var(--color-text-muted); }
.grid-icon-text--all     { color: var(--color-primary); }

.grid-label {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  text-align: center;
  line-height: var(--leading-tight);
}

/* ─── Admin portal entrance ───────────────────────────────────── */
.admin-card {
  border-color: var(--color-primary-tint);
}

.admin-row {
  display: flex;
  align-items: center;
}

.admin-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background-color: var(--color-primary-tint);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: var(--space-4);
}

.admin-icon-text {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.admin-label-group {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.admin-label {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: var(--leading-tight);
}

.admin-sublabel {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.admin-arrow {
  font-size: var(--text-xl);
  color: var(--color-primary);
  flex-shrink: 0;
  margin-left: var(--space-3);
}

.admin-notify-row {
  margin-top: var(--space-4);
  padding-top: var(--space-4);
  border-top: 1rpx solid var(--color-border-light);
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.admin-notify-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.admin-notify-title {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: var(--leading-tight);
}

.admin-notify-subtitle {
  margin-top: 4rpx;
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  line-height: var(--leading-normal);
}

.admin-notify-btn {
  height: 56rpx;
  min-width: 136rpx;
  padding: 0 var(--space-4);
  border-radius: 28rpx;
  border: 1rpx solid var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.admin-notify-btn--active {
  background-color: var(--color-primary-tint);
}

.admin-notify-btn-text {
  display: block;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-primary);
  line-height: 56rpx;
  white-space: nowrap;
}

/* ─── Modal mask ──────────────────────────────────────────────── */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(31, 27, 36, 0.42);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
  z-index: 200;
}

.modal-mask--visible {
  opacity: 1;
  pointer-events: auto;
}

.login-sheet,
.recharge-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--color-surface);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: var(--space-3) var(--space-6) var(--space-10);
  transform: translateY(100%);
  transition: transform 0.32s cubic-bezier(0.32, 0.72, 0, 1);
}

.login-sheet--open,
.recharge-sheet--open {
  transform: translateY(0);
}

.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  background-color: var(--color-border);
  border-radius: var(--radius-pill);
  margin: 0 auto var(--space-5);
}

.sheet-title {
  font-size: var(--text-md);
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
  text-align: center;
  letter-spacing: var(--tracking-tight);
  margin-bottom: var(--space-6);
}

/* ─── Recharge sheet ──────────────────────────────────────────── */
.recharge-summary {
  border-radius: var(--radius-xl);
  background-color: var(--color-bg-subtle);
  padding: var(--space-5);
  margin-bottom: var(--space-6);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  margin-bottom: var(--space-2);
}

.summary-amount-row {
  display: flex;
  align-items: baseline;
}

.summary-symbol {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-right: var(--space-1);
}

.summary-amount {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1;
}

.summary-bonus {
  font-size: var(--text-xs);
  color: var(--color-primary);
  margin-top: var(--space-2);
}

/* ─── Login sheet ─────────────────────────────────────────────── */
.avatar-chooser {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--space-6);
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-pill);
  padding: 0;
  margin: 0 auto;
  background: transparent;
  border: none;
  outline: none;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-pill);
  display: block;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-pill);
  border: 4rpx dashed var(--color-border);
  background-color: var(--color-bg-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-plus {
  font-size: var(--text-2xl);
  color: var(--color-text-muted);
  line-height: 1;
}

.avatar-hint {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-top: var(--space-2);
  display: block;
}

.nickname-wrap {
  background-color: var(--color-bg-subtle);
  border-radius: var(--radius-md);
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-6);
}

.nickname-label {
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-text-muted);
  letter-spacing: var(--tracking-wider);
  display: block;
  margin-bottom: var(--space-2);
}

.nickname-input {
  width: 100%;
  height: 72rpx;
  font-size: var(--text-base);
  color: var(--color-text-primary);
  font-weight: 500;
  background: none;
  padding: 0;
}

.nickname-placeholder {
  color: var(--color-text-muted);
  font-size: var(--text-base);
  font-weight: 400;
}

.sheet-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  padding: 0;
  margin: 0 0 var(--space-4);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill);
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-size: var(--text-base);
  font-weight: 600;
  letter-spacing: var(--tracking-wide);
  box-shadow: 0 8rpx 32rpx rgba(143, 107, 233, 0.32);
}

.skip-link {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  padding: var(--space-2) var(--space-4);
}
